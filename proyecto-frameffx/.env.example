# ──────────────────────────────────────────────────────────────
# .env.example — copia este archivo como .env y rellena los valores
# El archivo .env NUNCA se versiona en git (está en .gitignore)
# ──────────────────────────────────────────────────────────────

# Django
SECRET_KEY=django-insecure-clave-de-desarrollo-local
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Stripe (TEST MODE) ─────────────────────────────────────────
# Obtén tus claves en https://dashboard.stripe.com/test/apikeys
# Asegúrate de que el modo "Test" esté activo en el dashboard

STRIPE_PUBLIC_KEY=pk_test_12345
STRIPE_SECRET_KEY=sk_test_12345

# El webhook secret solo es necesario si usas `stripe listen` localmente
# para recibir eventos asíncronos. Para la demo del TFG puedes dejarlo en blanco.
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
