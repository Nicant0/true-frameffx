# ──────────────────────────────────────────────────────────────
# .env.example — Copia este archivo como .env (desarrollo) o
# .env.prod (producción) y rellena los valores reales.
# NUNCA versiones .env ni .env.prod en git (están en .gitignore).
# ──────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────
SECRET_KEY=django-insecure-clave-de-desarrollo-local
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos ─────────────────────────────────────────────
# En desarrollo local se usa SQLite automáticamente (no hace falta configurar esto).
# En producción, establecer DB_ENGINE=django.db.backends.postgresql y el resto.
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=frameffx_db
DB_USER=frameffx_user
DB_PASSWORD=contraseña-segura-aqui
DB_HOST=postgres
DB_PORT=5432

# ── HTTPS / Seguridad (solo producción) ───────────────────────
# Activar SOLO después de tener el certificado SSL. Si se activa antes
# de tener SSL, el servidor entrará en un bucle de redirecciones.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ── Email ─────────────────────────────────────────────────────
# En desarrollo se puede dejar el backend de consola (imprime emails en terminal).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Stripe ────────────────────────────────────────────────────
# Obtén tus claves en https://dashboard.stripe.com/test/apikeys
# Asegúrate de que el modo "Test" esté activo en el dashboard para desarrollo.
STRIPE_PUBLIC_KEY=pk_placeholder_aqui
STRIPE_SECRET_KEY=sk_placeholder_aqui
# El webhook secret se obtiene al crear el endpoint en el dashboard de Stripe.
# En local, usa: stripe listen --forward-to localhost:8000/products/webhook/stripe/
STRIPE_WEBHOOK_SECRET=whsec_placeholder_aqui

# ── Google OAuth (opcional) ───────────────────────────────────
# Configura las credenciales desde el panel de Django Admin (Sites > Social Applications).
# Si no usas OAuth de Google, puedes dejar estas variables vacías.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
